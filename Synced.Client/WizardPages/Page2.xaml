<Page x:Class="Synced.Client.WizardPages.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Synced.Client.WizardPages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page2">

    <StackPanel>
        <Label>服务器</Label>
        <TextBox AcceptsReturn="False" TextChanged="WizardServer_TextChanged" x:Name="WizardServer"></TextBox>
        <Label>用户名</Label>
        <TextBox AcceptsReturn="False" x:Name="WizardUsername" TextChanged="WizardUsername_TextChanged"></TextBox>
        <Label>密码</Label>
        <PasswordBox  x:Name="WizardPassword" PasswordChar="*" PasswordChanged="WizardPassword_PasswordChanged"></PasswordBox>
    </StackPanel>
</Page>
